# ============================================
# Liberty Canvas — Git 防壁 (secrets never leave the machine)
# ============================================

# 📦 依存関係 (CI は npm ci で独自インストール)
node_modules/
.pnpm-store/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/install-state.gz

# 🏗️ ビルド出力 (環境依存 — 絶対にコミットしない)
.next/
out/
build/
dist/
.unlighthouse/
tsconfig.tsbuildinfo
*.tsbuildinfo

# 🔐 セキュリティ・環境変数 (★最重要 — APIキー流出防止)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
# Catch-all for any other dotenv variants; allow committed templates only
.env.*
!.env.example
!.env.sample
!.env.template
*.pem
*.key
*.p12
*.pfx
secrets/
credentials.json
service-account*.json

# 🧪 テスト・ログ・キャッシュ
.eslintcache
.stylelintcache
coverage/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.turbo/
.cache/
.parcel-cache/
.vite/

# 🎭 Playwright / e2e
.playwright-browsers/
test-results/
playwright-report/
blob-report/

# ☁️ デプロイ・ローカルランタイム (トークン含むことあり)
.vercel/
artifacts/

# 🗄 ローカルデータストア
data/*.json

# 💻 IDE / OS
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
.DS_Store
Thumbs.db
Desktop.ini

# 📄 一時・雑多
*.tmp
*.temp
*.bak
.w3c-home.html
